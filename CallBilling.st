Object subclass: #PhoneNumber	instanceVariableNames: 'number locality country'	classVariableNames: ''	package: 'CallBilling'!!PhoneNumber methodsFor: 'initialization' stamp: '2026-05-19T15:21:03.968-03:00'!initializeNumber: aNumber locality: aLocality country: aCountry    number := aNumber.    locality := aLocality.    country := aCountry! !!PhoneNumber methodsFor: 'accessing' stamp: '2026-05-19T15:19:07.233-03:00'!country    ^ country ! !!PhoneNumber methodsFor: 'accessing' stamp: '2026-05-19T15:19:17.768-03:00'!locality    ^ locality! !!PhoneNumber methodsFor: 'comparing' stamp: '2026-05-20T03:24:38.013-03:00'!isSameCountryAs: anotherPhoneNumber	^ country = anotherPhoneNumber country! !!PhoneNumber methodsFor: 'comparing' stamp: '2026-05-20T03:24:45.399-03:00'!isSameLocalityAs: anotherPhoneNumber	^ locality = anotherPhoneNumber locality! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!PhoneNumber class	instanceVariableNames: ''!!PhoneNumber class methodsFor: 'instance creation' stamp: '2026-05-19T15:21:12.916-03:00'!number: aNumber locality: aLocality country: aCountry    ^ self new        initializeNumber: aNumber locality: aLocality country: aCountry! !Object subclass: #MonthlyBilling	instanceVariableNames: 'subscriber period tariffResolver localCalls nationalAndInternationalCalls'	classVariableNames: ''	package: 'CallBilling'!!MonthlyBilling methodsFor: 'initialization' stamp: '2026-05-20T02:52:08.992-03:00'!initializeSubscriber: aSubscriber period: aMonth    subscriber := aSubscriber.    period := aMonth.    tariffResolver := TariffResolver new.    localCalls := OrderedCollection new.    nationalAndInternationalCalls := OrderedCollection new.! !!MonthlyBilling methodsFor: 'translating' stamp: '2026-05-20T02:52:31.563-03:00'!generate    subscriber calls do: [ :call | call addYourselfTo: self ]! !!MonthlyBilling methodsFor: 'adding' stamp: '2026-05-20T02:52:37.428-03:00'!addLocalCall: aCall    localCalls add: aCall! !!MonthlyBilling methodsFor: 'adding' stamp: '2026-05-20T02:52:41.316-03:00'!addNationalOrInternationalCall: aCall    nationalAndInternationalCalls add: aCall! !!MonthlyBilling methodsFor: 'accessing' stamp: '2026-05-20T02:52:58.815-03:00'!basicFee    ^ subscriber basicMonthlyFee! !!MonthlyBilling methodsFor: 'calculating' stamp: '2026-05-20T02:53:42.91-03:00'!localCallsCost    ^ localCalls inject: 0 into: [ :sum :call |         sum + (call costWith: tariffResolver) ]! !!MonthlyBilling methodsFor: 'calculating' stamp: '2026-05-20T02:53:57.107-03:00'!nationalAndInternationalCallsCost	^ nationalAndInternationalCalls inject: 0 into: [ :sum :call | 		sum + (call costWith: tariffResolver) ]! !!MonthlyBilling methodsFor: 'calculating' stamp: '2026-05-20T02:54:17.851-03:00'!totalCost	^ self basicFee 		+ self localCallsCost 		+ self nationalAndInternationalCallsCost! !!MonthlyBilling methodsFor: 'printing' stamp: '2026-05-20T03:00:40.594-03:00'!printInvoice	Transcript		nextPutAll: 'Monthly Billing'; cr;		nextPutAll: '----------------'; cr;			nextPutAll: 'Subscriber: '; nextPutAll: subscriber name; cr;		nextPutAll: 'Period: '; nextPutAll: period printString; cr;		nextPutAll: 'Charges'; cr;		nextPutAll: '----------------'; cr;			nextPutAll: 'Basic fee: $'; nextPutAll: self basicFee printString; cr;		nextPutAll: 'Local calls: $'; nextPutAll: self localCallsCost printString; cr;		nextPutAll: 'National/International calls: $'; nextPutAll: self nationalAndInternationalCallsCost printString; cr;		nextPutAll: '---------------'; cr;		nextPutAll: 'TOTAL: $'; nextPutAll: self totalCost printString; cr.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!MonthlyBilling class	instanceVariableNames: ''!!MonthlyBilling class methodsFor: 'instance creation' stamp: '2026-05-20T02:51:53.1-03:00'!for: aSubscriber period: aMonth    ^ self new        initializeSubscriber: aSubscriber period: aMonth;        yourself! !Object subclass: #TariffResolver	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling'!!TariffResolver methodsFor: 'double dispatch' stamp: '2026-05-20T02:42:17.963-03:00'!costForLocalCallAt: aDateAndTime duration: minutes    ^ (LocalTariff for: aDateAndTime) calculateCost: minutes! !!TariffResolver methodsFor: 'double dispatch' stamp: '2026-05-20T02:44:45.08-03:00'!costForInternationalCallTo: aCountry duration: minutes    ^ (InternationalTariff forCountry: aCountry) calculateCost: minutes! !!TariffResolver methodsFor: 'double dispatch' stamp: '2026-05-20T02:42:22.605-03:00'!costForNationalCallTo: aLocality duration: minutes    ^ (NationalTariff forLocality: aLocality) calculateCost: minutes! !Object subclass: #Call	instanceVariableNames: 'startTime duration destinationNumber fromNumber'	classVariableNames: ''	package: 'CallBilling'!!Call methodsFor: 'initialization' stamp: '2026-05-20T02:43:38.846-03:00'!initializeFrom: anOriginNumber to: aDestinationNumber startTime: aDateAndTime endTime: anotherDateAndTime    fromNumber := anOriginNumber.    destinationNumber := aDestinationNumber.    startTime := aDateAndTime.    duration := anotherDateAndTime - aDateAndTime.! !!Call methodsFor: 'accessing' stamp: '2026-05-20T02:45:13.415-03:00'!destinationNumber 	^destinationNumber ! !!Call methodsFor: 'subclass responsibility' stamp: '2026-05-20T02:50:49.179-03:00'!costWith: aTariffResolver	^self subclassResponsibility! !!Call methodsFor: 'subclass responsibility' stamp: '2026-05-20T02:51:02.244-03:00'!addYourselfTo: aMonthlyBilling	^ self subclassResponsibility! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Call class	instanceVariableNames: ''!!Call class methodsFor: 'instance creation' stamp: '2026-05-20T02:01:22.513-03:00'!from: aSourceNumber to: aDestinationNumber startTime: aDateAndTime endTime: anotherDateAndTime    | callClass |    (aSourceNumber isSameCountryAs: aDestinationNumber)         ifFalse: [ callClass := InternationalCall ].    (aSourceNumber isSameLocalityAs: aDestinationNumber)         ifFalse: [ callClass isNil ifTrue: [ callClass := NationalCall ]].    callClass isNil ifTrue: [ callClass := LocalCall ].    ^ callClass         from: aSourceNumber         to: aDestinationNumber         startTime: aDateAndTime         endTime: anotherDateAndTime! !Call subclass: #LocalCall	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling'!!LocalCall methodsFor: 'double dispatch' stamp: '2026-05-20T02:51:30.888-03:00'!addYourselfTo: aMonthlyBilling    aMonthlyBilling addLocalCall: self! !!LocalCall methodsFor: 'calculating' stamp: '2026-05-20T02:42:00.49-03:00'!costWith: aTariffResolver    ^ aTariffResolver costForLocalCallAt: startTime        duration: duration asMinutes! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!LocalCall class	instanceVariableNames: ''!!LocalCall class methodsFor: 'instance creation' stamp: '2026-05-20T02:03:57.64-03:00'!from: aSourceNumber to: aDestinationNumber startTime: aDateAndTime endTime: anotherDateAndTime    ^ self new         initializeFrom: aSourceNumber         to: aDestinationNumber         startTime: aDateAndTime         endTime: anotherDateAndTime! !Call subclass: #InternationalCall	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling'!!InternationalCall methodsFor: 'calculating' stamp: '2026-05-20T02:45:26.654-03:00'!costWith: aTariffResolver	^ aTariffResolver costForInternationalCallTo: destinationNumber country		duration: duration asMinutes! !!InternationalCall methodsFor: 'double dispatch' stamp: '2026-05-20T02:51:10.66-03:00'!addYourselfTo: aMonthlyBilling    aMonthlyBilling addNationalOrInternationalCall: self! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!InternationalCall class	instanceVariableNames: ''!!InternationalCall class methodsFor: 'instance creation' stamp: '2026-05-20T02:05:26.346-03:00'!from: aSourceNumber to: aDestinationNumber startTime: aDateAndTime endTime: anotherDateAndTime    ^ self new         initializeFrom: aSourceNumber         to: aDestinationNumber         startTime: aDateAndTime         endTime: anotherDateAndTime! !Object subclass: #Subscriber	instanceVariableNames: 'name basicMonthlyFee calls'	classVariableNames: ''	package: 'CallBilling'!!Subscriber methodsFor: 'initialization' stamp: '2026-05-20T02:19:48.957-03:00'!initializeName: aName basicMonthlyFee: aFee	name := aName.	basicMonthlyFee := aFee.	calls := OrderedCollection new.! !!Subscriber methodsFor: 'adding' stamp: '2026-05-20T02:20:04.571-03:00'!addCall: aCall    calls add: aCall! !!Subscriber methodsFor: 'accessing' stamp: '2026-05-20T03:06:36.762-03:00'!basicMonthlyFee 	^ basicMonthlyFee! !!Subscriber methodsFor: 'accessing' stamp: '2026-05-20T03:06:42.233-03:00'!calls 	^calls ! !!Subscriber methodsFor: 'accessing' stamp: '2026-05-20T03:14:29.384-03:00'!name	^name! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Subscriber class	instanceVariableNames: ''!!Subscriber class methodsFor: 'instance creation' stamp: '2026-05-20T02:19:24.119-03:00'!name: aName basicMonthlyFee: aFee	^ self new		initializeName: aName basicMonthlyFee: aFee;		yourself! !Object subclass: #Tariff	instanceVariableNames: 'ratePerMinute'	classVariableNames: ''	package: 'CallBilling'!!Tariff methodsFor: 'initialization' stamp: '2026-05-19T15:34:38.602-03:00'!initializeWithRate: aRate    ratePerMinute := aRate! !!Tariff methodsFor: 'calculating' stamp: '2026-05-19T15:35:12.784-03:00'!calculateCost: aMinutesDuration	^ ratePerMinute * aMinutesDuration  ! !Tariff subclass: #NationalTariff	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!NationalTariff class	instanceVariableNames: ''!!NationalTariff class methodsFor: 'instance creation' stamp: '2026-05-19T15:32:20.925-03:00'!forLocality: aLocality    | rate |    rate := self rateTable at: aLocality ifAbsent: [ 0.15 ].    ^ self new initializeWithRate: rate! !!NationalTariff class methodsFor: 'data' stamp: '2026-05-19T15:32:26.656-03:00'!rateTable    ^ Dictionary new        at: 'Cordoba' put: 0.15;        at: 'Rosario' put: 0.18;        at: 'Mendoza' put: 0.20;        yourself! !Tariff subclass: #LocalTariff	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!LocalTariff class	instanceVariableNames: ''!!LocalTariff class methodsFor: 'instance creation' stamp: '2026-05-19T15:48:33.85-03:00'!for: aDateAndTime    ((aDateAndTime dayOfWeek between: 1 and: 5 ) and: [aDateAndTime hour between: 8 and: 19])        ifTrue: [ ^ self new initializeWithRate: 0.20 ].    ^ self new initializeWithRate: 0.10! !Tariff subclass: #InternationalTariff	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!InternationalTariff class	instanceVariableNames: ''!!InternationalTariff class methodsFor: 'instance creation' stamp: '2026-05-19T15:37:00.49-03:00'!forCountry: aCountry    | rate |    rate := self rateTable at: aCountry ifAbsent: [ 0.50 ].    ^ self new initializeWithRate: rate! !!InternationalTariff class methodsFor: 'data' stamp: '2026-05-19T15:37:06.795-03:00'!rateTable    ^ Dictionary new        at: 'Brasil' put: 0.50;        at: 'Uruguay' put: 0.45;        at: 'España' put: 1.20;        at: 'USA' put: 1.50;        yourself! !Call subclass: #NationalCall	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling'!!NationalCall methodsFor: 'calculating' stamp: '2026-05-20T02:41:51.937-03:00'!costWith: aTariffResolver	^ aTariffResolver costForNationalCallTo: destinationNumber locality        duration: duration asMinutes! !!NationalCall methodsFor: 'double dispatch' stamp: '2026-05-20T02:51:21.752-03:00'!addYourselfTo: aMonthlyBilling    aMonthlyBilling addNationalOrInternationalCall: self! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!NationalCall class	instanceVariableNames: ''!!NationalCall class methodsFor: 'instance creation' stamp: '2026-05-20T02:04:52.614-03:00'!from: aSourceNumber to: aDestinationNumber startTime: aDateAndTime endTime: anotherDateAndTime	^ self new         initializeFrom: aSourceNumber         to: aDestinationNumber         startTime: aDateAndTime         endTime: anotherDateAndTime! !