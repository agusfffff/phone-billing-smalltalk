TestCase subclass: #MonthlyBillingTest	instanceVariableNames: 'billing'	classVariableNames: ''	package: 'CallBilling-Tests'!!MonthlyBillingTest methodsFor: 'running' stamp: '2026-05-20T03:05:35.839-03:00'!setUp    | subscriber |    subscriber := Subscriber name: 'Maria Agustina' basicMonthlyFee: 10.00.    subscriber addCall: (Call        from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')        to: (PhoneNumber number: '1187654321' locality: 'Buenos Aires' country: 'Argentina')        startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)        endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).    subscriber addCall: (Call        from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')        to: (PhoneNumber number: '3514567890' locality: 'Cordoba' country: 'Argentina')        startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)        endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).    subscriber addCall: (Call        from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')        to: (PhoneNumber number: '5511987654' locality: 'Sao Paulo' country: 'Brasil')        startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)        endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).    billing := MonthlyBilling for: subscriber period: (Month year: 2024 month: 1).    billing generate.! !!MonthlyBillingTest methodsFor: 'tests' stamp: '2026-05-20T03:03:29.005-03:00'!testBasicFee    self assert: billing basicFee equals: 10.00.! !!MonthlyBillingTest methodsFor: 'tests' stamp: '2026-05-20T03:06:56.549-03:00'!testLocalCallsCost    self assert: billing localCallsCost equals: 2.00.! !!MonthlyBillingTest methodsFor: 'tests' stamp: '2026-05-20T03:07:05.939-03:00'!testNationalAndInternationalCallsCost	self assert: billing nationalAndInternationalCallsCost equals: 6.50.! !!MonthlyBillingTest methodsFor: 'tests' stamp: '2026-05-20T03:07:13.256-03:00'!testTotalCost    self assert: billing totalCost equals: 18.50.! !!MonthlyBillingTest methodsFor: 'tests' stamp: '2026-05-20T03:07:21.325-03:00'!testEmptyBilling    | emptyBilling subscriber |    subscriber := Subscriber name: 'Juan Perez' basicMonthlyFee: 15.00.    emptyBilling := MonthlyBilling for: subscriber period: (Month year: 2024 month: 1).    emptyBilling generate.    self assert: emptyBilling totalCost equals: 15.00.! !!MonthlyBillingTest methodsFor: 'tests' stamp: '2026-05-20T03:10:45.46-03:00'!testNationalAndInternationalDifferentRates	| subscriber |	subscriber := Subscriber name: 'Test' basicMonthlyFee: 0.		subscriber addCall: (Call		from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')		to: (PhoneNumber number: '3414567890' locality: 'Rosario' country: 'Argentina')		startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)		endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).			subscriber addCall: (Call		from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')		to: (PhoneNumber number: '59899123456' locality: 'Montevideo' country: 'Uruguay')		startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)		endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).			billing := MonthlyBilling for: subscriber period: (Month year: 2024 month: 1).	billing generate.	self assert: billing nationalAndInternationalCallsCost equals: 6.30.! !!MonthlyBillingTest methodsFor: 'tests' stamp: '2026-05-20T03:15:30.059-03:00'!testPrintInvoice    | subscriber |    subscriber := Subscriber name: 'Maria Agustina' basicMonthlyFee: 10.00.        subscriber addCall: (Call        from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')        to: (PhoneNumber number: '1187654321' locality: 'Buenos Aires' country: 'Argentina')        startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)        endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).    subscriber addCall: (Call        from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')        to: (PhoneNumber number: '3514567890' locality: 'Cordoba' country: 'Argentina')        startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)        endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).    subscriber addCall: (Call        from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')        to: (PhoneNumber number: '5511987654' locality: 'Sao Paulo' country: 'Brasil')        startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)        endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0)).    subscriber addCall: (Call        from: (PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina')        to: (PhoneNumber number: '1187654321' locality: 'Buenos Aires' country: 'Argentina')        startTime: (DateAndTime year: 2024 month: 1 day: 20 hour: 10 minute: 0 second: 0)        endTime: (DateAndTime year: 2024 month: 1 day: 20 hour: 10 minute: 10 second: 0)).    billing := MonthlyBilling for: subscriber period: (Month year: 2024 month: 1).    billing generate.    billing printInvoice.        self assert: billing basicFee equals: 10.00.    self assert: billing localCallsCost equals: 3.00.    self assert: billing nationalAndInternationalCallsCost equals: 6.50.    self assert: billing totalCost equals: 19.50.! !TestCase subclass: #PhoneNumberTest	instanceVariableNames: ''	classVariableNames: ''	package: 'CallBilling-Tests'!!PhoneNumberTest methodsFor: 'tests' stamp: '2026-05-19T15:23:11.846-03:00'!testSameCountry    | number1 number2 |    number1 := PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina'.    number2 := PhoneNumber number: '1187654321' locality: 'Cordoba' country: 'Argentina'.    self assert: (number1 isSameCountryAs: number2).! !!PhoneNumberTest methodsFor: 'tests' stamp: '2026-05-19T15:24:05.472-03:00'!testDifferentCountry    | number1 number2 |    number1 := PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina'.    number2 := PhoneNumber number: '5511987654' locality: 'Sao Paulo' country: 'Brasil'.    self deny: (number1 isSameCountryAs: number2).! !!PhoneNumberTest methodsFor: 'tests' stamp: '2026-05-19T15:24:11.492-03:00'!testSameLocality    | number1 number2 |    number1 := PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina'.    number2 := PhoneNumber number: '1187654321' locality: 'Buenos Aires' country: 'Argentina'.    self assert: (number1 isSameLocalityAs: number2).! !!PhoneNumberTest methodsFor: 'tests' stamp: '2026-05-19T15:24:18.876-03:00'!testDifferentLocality    | number1 number2 |    number1 := PhoneNumber number: '1134567890' locality: 'Buenos Aires' country: 'Argentina'.    number2 := PhoneNumber number: '3514567890' locality: 'Cordoba' country: 'Argentina'.    self deny: (number1 isSameLocalityAs: number2).! !TestCase subclass: #CallTests	instanceVariableNames: 'cordobaNumber brasilNumber originNumber resolver'	classVariableNames: ''	package: 'CallBilling-Tests'!!CallTests methodsFor: 'running' stamp: '2026-05-20T02:48:38.041-03:00'!setUp    | buenosAiresNumber |    buenosAiresNumber := PhoneNumber         number: '1134567890'         locality: 'Buenos Aires'         country: 'Argentina'.    cordobaNumber := PhoneNumber         number: '3514567890'         locality: 'Cordoba'         country: 'Argentina'.    brasilNumber := PhoneNumber         number: '5511987654'         locality: 'Sao Paulo'         country: 'Brasil'.    originNumber := buenosAiresNumber.    resolver := TariffResolver new.! !!CallTests methodsFor: 'tests' stamp: '2026-05-20T02:49:09.108-03:00'!testLocalCallPeakHour	| call |	call := Call		from: originNumber		to: (PhoneNumber number: '1187654321' locality: 'Buenos Aires' country: 'Argentina')		startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)		endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0).	self assert: (call costWith: resolver) equals: 2.00.! !!CallTests methodsFor: 'tests' stamp: '2026-05-20T02:49:22.189-03:00'!testLocalCallOffPeakHour	| call |	call := Call		from: originNumber		to: (PhoneNumber number: '1187654321' locality: 'Buenos Aires' country: 'Argentina')		startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 22 minute: 0 second: 0)		endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 22 minute: 10 second: 0).	self assert: (call costWith: resolver) equals: 1.00.! !!CallTests methodsFor: 'tests' stamp: '2026-05-20T02:49:18.356-03:00'!testNationalCall	| call |	call := Call		from: originNumber		to: cordobaNumber 		startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)		endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0).	self assert: (call costWith: resolver) equals: 1.50.! !!CallTests methodsFor: 'tests' stamp: '2026-05-20T02:49:25.275-03:00'!testInternationalCall	| call |	call := Call		from: originNumber		to: brasilNumber 		startTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 0 second: 0)		endTime: (DateAndTime year: 2024 month: 1 day: 15 hour: 10 minute: 10 second: 0).	self assert: (call costWith: resolver) equals: 5.00.! !